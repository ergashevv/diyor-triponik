@@ -0,0 +1,450 @@
+import {
+  MOCK_DESTINATIONS,
+  HOTEL_PREFIXES,
+  HOTEL_SUFFIXES,
+  ROOM_TYPES,
+  BOARD_TYPES,
+  PAYMENT_TYPES,
+  AMENITIES,
+  ATTRACTIONS_BY_CITY,
+  HOTEL_DESCRIPTIONS,
+  REVIEW_COMMENTS,
+  HOTEL_IMAGE_URLS,
+  BED_CONFIGS,
+  VIEW_TYPES,
+} from './mockData';
+import type { HotelItem, Room, Rate, DestinationSuggestion } from './types';
+
+/**
+ * Random number generator utilities
+ */
+export const random = {
+  int: (min: number, max: number): number => Math.floor(Math.random() * (max - min + 1)) + min,
+  float: (min: number, max: number, decimals = 2): number => 
+    parseFloat((Math.random() * (max - min) + min).toFixed(decimals)),
+  pick: <T>(array: T[]): T => array[Math.floor(Math.random() * array.length)],
+  pickMultiple: <T>(array: T[], count: number): T[] => {
+    const shuffled = [...array].sort(() => 0.5 - Math.random());
+    return shuffled.slice(0, Math.min(count, array.length));
+  },
+  boolean: (probability = 0.5): boolean => Math.random() < probability,
+  delay: (min = 400, max = 1200): number => random.int(min, max),
+};
+
+/**
+ * Generate a unique ID
+ */
+export function generateId(prefix: string): string {
+  return `${prefix}_${Date.now()}_${random.int(1000, 9999)}`;
+}
+
+/**
+ * Generate hotel code based on destination and index
+ */
+export function generateHotelCode(destinationCode: string, index: number): string {
+  return `${destinationCode}_HOTEL_${String(index).padStart(3, '0')}`;
+}
+
+/**
+ * Generate room code
+ */
+export function generateRoomCode(hotelCode: string, index: number): string {
+  return `${hotelCode}_ROOM_${String(index).padStart(2, '0')}`;
+}
+
+/**
+ * Get destination by keyword or code
+ */
+export function findDestination(keyword: string): DestinationSuggestion | undefined {
+  const normalized = keyword.toLowerCase().trim();
+  return MOCK_DESTINATIONS.find(
+    (dest) =>
+      dest.name.toLowerCase().includes(normalized) ||
+      dest.id.toLowerCase() === normalized
+  );
+}
+
+/**
+ * Get random coordinates near a city center
+ */
+export function getRandomCoordinates(centerLat: number | undefined, centerLng: number | undefined, radiusKm = 5): { lat: number; lng: number } {
+  const lat = centerLat || 41.3111; // Default to Tashkent
+  const lng = centerLng || 69.2797;
+  const radiusDegrees = radiusKm / 111; // Approximate conversion
+  const angle = random.float(0, 2 * Math.PI);
+  const distance = random.float(0, radiusDegrees);
+  
+  return {
+    lat: parseFloat((lat + distance * Math.cos(angle)).toFixed(6)),
+    lng: parseFloat((lng + distance * Math.sin(angle)).toFixed(6)),
+  };
+}
+
+/**
+ * Calculate distance between two coordinates (in km)
+ */
+export function calculateDistance(lat1: number, lng1: number, lat2: number, lng2: number): number {
+  const R = 6371; // Earth's radius in km
+  const dLat = (lat2 - lat1) * Math.PI / 180;
+  const dLng = (lng2 - lng1) * Math.PI / 180;
+  const a = 
+    Math.sin(dLat / 2) * Math.sin(dLat / 2) +
+    Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
+    Math.sin(dLng / 2) * Math.sin(dLng / 2);
+  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
+  return parseFloat((R * c).toFixed(1));
+}
+
+/**
+ * Generate hotel name based on star rating and destination
+ */
+export function generateHotelName(stars: number, destination: string): string {
+  const prefix = random.pick(HOTEL_PREFIXES[stars as 3 | 4 | 5] || HOTEL_PREFIXES[4]);
+  const suffix = random.pick(HOTEL_SUFFIXES);
+  const includeCity = random.boolean(0.7);
+  
+  if (includeCity) {
+    return `${prefix} ${destination} ${suffix}`;
+  }
+  return `${prefix} ${suffix}`;
+}
+
+/**
+ * Generate hotel description
+ */
+export function generateHotelDescription(stars: number): string {
+  const descriptions = HOTEL_DESCRIPTIONS[stars as 3 | 4 | 5] || HOTEL_DESCRIPTIONS[4];
+  return random.pick(descriptions);
+}
+
+/**
+ * Generate amenities for a hotel based on star rating
+ */
+export function generateAmenities(stars: number): string[] {
+  const baseAmenities = ['wifi', 'ac', 'reception24'];
+  const allAmenities = AMENITIES.map(a => a.id);
+  
+  let count: number;
+  if (stars === 5) count = random.int(12, 18);
+  else if (stars === 4) count = random.int(8, 12);
+  else count = random.int(4, 8);
+  
+  const selected = new Set(baseAmenities);
+  while (selected.size < Math.min(count, allAmenities.length)) {
+    selected.add(random.pick(allAmenities));
+  }
+  
+  return Array.from(selected);
+}
+
+/**
+ * Generate room rates for a room
+ */
+export function generateRates(
+  hotelCode: string,
+  roomCode: string,
+  basePrice: number,
+  adults: number,
+  children: number
+): Rate[] {
+  const rateCount = random.int(1, 3);
+  const rates: Rate[] = [];
+  
+  for (let i = 0; i < rateCount; i++) {
+    const boardType = random.pick(BOARD_TYPES);
+    const paymentType = random.pick(PAYMENT_TYPES);
+    const refundable = random.boolean(0.7);
+    
+    // Adjust price based on board type
+    let priceMultiplier = 1;
+    if (boardType.code === 'BB') priceMultiplier = 1.1;
+    else if (boardType.code === 'HB') priceMultiplier = 1.25;
+    else if (boardType.code === 'FB') priceMultiplier = 1.4;
+    else if (boardType.code === 'AI') priceMultiplier = 1.6;
+    
+    // Adjust for payment type
+    if (paymentType.code === 'AT_HOTEL') priceMultiplier *= 0.95;
+    
+    // Adjust for refundability
+    if (!refundable) priceMultiplier *= 0.9;
+    
+    const net = parseFloat((basePrice * priceMultiplier).toFixed(2));
+    const selling = parseFloat((net * 1.1).toFixed(2));
+    
+    rates.push({
+      rateKey: generateId('RATE'),
+      boardCode: boardType.code,
+      boardName: boardType.name,
+      paymentType: paymentType.code as 'AT_WEB' | 'AT_HOTEL',
+      refundable,
+      cancellationPolicies: refundable ? [
+        {
+          from: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
+          amount: parseFloat((net * 0.5).toFixed(2)),
+          currency: 'USD',
+        },
+      ] : undefined,
+      price: {
+        net,
+        selling,
+        currency: 'USD',
+        taxesIncluded: random.boolean(0.5),
+      },
+    });
+  }
+  
+  return rates;
+}
+
+/**
+ * Generate rooms for a hotel
+ */
+export function generateRooms(
+  hotelCode: string,
+  stars: number,
+  basePrice: number,
+  adults: number,
+  children: number
+): Room[] {
+  const roomCount = random.int(1, 3);
+  const rooms: Room[] = [];
+  
+  const roomTypeKeys = Object.keys(ROOM_TYPES) as Array<keyof typeof ROOM_TYPES>;
+  
+  for (let i = 0; i < roomCount; i++) {
+    const roomTypeKey = roomTypeKeys[Math.min(i, roomTypeKeys.length - 1)];
+    const roomType = random.pick(ROOM_TYPES[roomTypeKey]);
+    const roomCode = generateRoomCode(hotelCode, i + 1);
+    
+    // Higher categories have higher prices
+    let roomPriceMultiplier = 1;
+    if (roomTypeKey === 'deluxe') roomPriceMultiplier = 1.3;
+    else if (roomTypeKey === 'suite') roomPriceMultiplier = 1.6;
+    else if (roomTypeKey === 'family') roomPriceMultiplier = 1.4;
+    
+    const roomBasePrice = parseFloat((basePrice * roomPriceMultiplier).toFixed(2));
+    
+    rooms.push({
+      code: roomCode,
+      name: roomType,
+      rates: generateRates(hotelCode, roomCode, roomBasePrice, adults, children),
+      maxAdults: roomTypeKey === 'family' ? 4 : 2,
+      maxChildren: roomTypeKey === 'family' ? 2 : 1,
+      bedConfiguration: random.pick(BED_CONFIGS),
+      sizeSquareMeters: random.int(14, 28),
+      viewType: random.pick(VIEW_TYPES),
+    });
+  }
+
+  return rooms;
+}
+
+/**
+ * Generate a mock hotel
+ */
+export function generateHotel(
+  destination: DestinationSuggestion,
+  index: number,
+  stars: number,
+  adults: number,
+  children: number
+): HotelItem {
+  const hotelCode = generateHotelCode(destination.id, index);
+  const coords = getRandomCoordinates(destination.lat, destination.lng);
+  const basePrice = random.int(50, 400);
+  const destLat = destination.lat || 41.3111;
+  const destLng = destination.lng || 69.2797;
+  const distance = calculateDistance(destLat, destLng, coords.lat, coords.lng);
+  
+  const distanceFromMetro = random.int(200, 1200);
+  const reviewCount = random.int(12, 250);
+  const reviewScore = parseFloat((7.2 + (stars - 3) * 0.6 + random.float(0, 1.2)).toFixed(1));
+  const isTopRated = stars >= 4 && random.boolean(0.35);
+
+  return {
+    code: hotelCode,
+    name: generateHotelName(stars, destination.name),
+    categoryName: `${stars}-yulduzli`,
+    stars,
+    latitude: coords.lat,
+    longitude: coords.lng,
+    distance,
+    distanceFromMetro,
+    address: `${destination.name} shahri, ${random.int(1, 50)}-ko'cha`,
+    city: destination.name,
+    countryCode: destination.countryCode || 'UZ',
+    thumbnail: random.pick(HOTEL_IMAGE_URLS),
+    images: Array.from({ length: 10 }, () => random.pick(HOTEL_IMAGE_URLS)),
+    rooms: generateRooms(hotelCode, stars, basePrice, adults, children),
+    reviewCount,
+    reviewScore,
+    isTopRated,
+  };
+}
+
+/**
+ * Filter hotels by criteria
+ */
+export function filterHotels(
+  hotels: HotelItem[],
+  filters: {
+    minPrice?: number;
+    maxPrice?: number;
+    stars?: number[];
+    boardTypes?: string[];
+    paymentTypes?: string[];
+  }
+): HotelItem[] {
+  return hotels.filter((hotel) => {
+    // Get min price from hotel rooms
+    const minRate = Math.min(
+      ...hotel.rooms.flatMap((room) =>
+        room.rates.map((rate) => rate.price.net)
+      )
+    );
+    
+    // Price filter
+    if (filters.minPrice !== undefined && minRate < filters.minPrice) return false;
+    if (filters.maxPrice !== undefined && minRate > filters.maxPrice) return false;
+    
+    // Stars filter
+    if (filters.stars && filters.stars.length > 0 && hotel.stars && !filters.stars.includes(hotel.stars)) {
+      return false;
+    }
+    
+    // Board types filter
+    if (filters.boardTypes && filters.boardTypes.length > 0) {
+      const hasBoardType = hotel.rooms.some((room) =>
+        room.rates.some((rate) => rate.boardCode && filters.boardTypes!.includes(rate.boardCode))
+      );
+      if (!hasBoardType) return false;
+    }
+    
+    // Payment types filter
+    if (filters.paymentTypes && filters.paymentTypes.length > 0) {
+      const hasPaymentType = hotel.rooms.some((room) =>
+        room.rates.some((rate) => filters.paymentTypes!.includes(rate.paymentType))
+      );
+      if (!hasPaymentType) return false;
+    }
+    
+    return true;
+  });
+}
+
+/**
+ * Sort hotels
+ */
+export function sortHotels(
+  hotels: HotelItem[],
+  sortBy: 'price' | 'stars' | 'distance',
+  order: 'asc' | 'desc' = 'asc'
+): HotelItem[] {
+  const sorted = [...hotels].sort((a, b) => {
+    let comparison = 0;
+    
+    if (sortBy === 'price') {
+      const aMin = Math.min(...a.rooms.flatMap(r => r.rates.map(rt => rt.price.net)));
+      const bMin = Math.min(...b.rooms.flatMap(r => r.rates.map(rt => rt.price.net)));
+      comparison = aMin - bMin;
+    } else if (sortBy === 'stars') {
+      comparison = (a.stars || 0) - (b.stars || 0);
+    } else if (sortBy === 'distance') {
+      comparison = (a.distance || 0) - (b.distance || 0);
+    }
+    
+    return order === 'asc' ? comparison : -comparison;
+  });
+  
+  return sorted;
+}
+
+/**
+ * Paginate results
+ */
+export function paginate<T>(items: T[], from: number, size: number): T[] {
+  return items.slice(from, from + size);
+}
+
+/**
+ * Generate hotel gallery images
+ */
+export function generateGallery(count = 8): string[] {
+  return random.pickMultiple(HOTEL_IMAGE_URLS, Math.min(count, HOTEL_IMAGE_URLS.length));
+}
+
+/**
+ * Generate reviews summary
+ */
+export function generateReviewsSummary(stars: number) {
+  const baseScore = stars === 5 ? 8.5 : stars === 4 ? 7.5 : 6.5;
+  const overallScore = random.float(baseScore, Math.min(baseScore + 1.5, 10), 1);
+  
+  return {
+    overall: overallScore,
+    cleanliness: random.float(overallScore - 0.5, overallScore + 0.5, 1),
+    comfort: random.float(overallScore - 0.5, overallScore + 0.5, 1),
+    location: random.float(overallScore - 0.5, overallScore + 0.5, 1),
+    service: random.float(overallScore - 0.5, overallScore + 0.5, 1),
+    valueForMoney: random.float(overallScore - 0.5, overallScore + 0.5, 1),
+    totalReviews: random.int(50, 500),
+  };
+}
+
+/**
+ * Generate individual reviews
+ */
+export function generateReviews(count = 5) {
+  const reviews = [];
+  const names = ['Aziz', 'Olim', 'Dilnoza', 'Kamola', 'Jahongir', 'Madina', 'Botir', 'Zarina'];
+  
+  for (let i = 0; i < count; i++) {
+    const isPositive = random.boolean(0.7);
+    const commentPool = isPositive ? REVIEW_COMMENTS.positive : 
+                       random.boolean(0.5) ? REVIEW_COMMENTS.neutral : REVIEW_COMMENTS.negative;
+    
+    reviews.push({
+      id: generateId('REVIEW'),
+      guestName: random.pick(names),
+      rating: isPositive ? random.float(8, 10, 1) : random.float(6, 8, 1),
+      comment: random.pick(commentPool),
+      date: new Date(Date.now() - random.int(1, 365) * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
+      verified: random.boolean(0.8),
+    });
+  }
+  
+  return reviews;
+}
+
+/**
+ * Simulate network delay
+ */
+export async function simulateDelay(min = 400, max = 1200): Promise<void> {
+  const delay = random.delay(min, max);
+  await new Promise((resolve) => setTimeout(resolve, delay));
+}
+
+/**
+ * Get attractions for destination
+ */
+export function getAttractions(destinationCode: string): string[] {
+  return ATTRACTIONS_BY_CITY[destinationCode] || ATTRACTIONS_BY_CITY.default;
+}
+
+/**
+ * Log mock API request (only in development)
+ */
+export function logMockRequest(endpoint: string, method: string, data?: any) {
+  if (process.dev) {
+    console.log(`[MOCK API] ${method} ${endpoint}`, data || '');
+  }
+}
+
+/**
+ * Log mock API response (only in development)
+ */
+export function logMockResponse(endpoint: string, data: any) {
+  if (process.dev) {
+    console.log(`[MOCK API] Response for ${endpoint}:`, data);
+  }
+}
