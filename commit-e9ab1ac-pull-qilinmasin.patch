+        categoryCode: hotel.categoryCode,
+        categoryName: hotel.categoryName,
+        destinationCode: hotel.destinationCode,
+        destinationName: hotel.destinationName,
+        checkIn: hotel.checkIn || new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
+        checkOut: hotel.checkOut || new Date(Date.now() + 12 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
+        rooms: hotel.rooms || [],
+        latitude: hotel.latitude,
+        longitude: hotel.longitude,
+      },
+    };
+  }
+
+  async book(payload: BookingRequest): Promise<BookingResponse> {
+    return bookHotel(payload);
+  }
+
+  async getSuggestions(query: string): Promise<DestinationSuggestion[]> {
+    return getSuggestions(query);
+  }
+
+  async cancelBooking(bookingReference: string): Promise<{ success: boolean; message: string }> {
+    return cancelBooking(bookingReference);
+  }
+}
diff --git a/app/lib/hotels/mockUtils.ts b/app/lib/hotels/mockUtils.ts
