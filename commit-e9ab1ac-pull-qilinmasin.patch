+
+const route = useRoute();
+
+/** Detail sahifaga havola: rateKey + sanalar (karta bosilganda inner page ga kirish) */
+const detailTo = computed(() => {
+  const rateKey = props.hotel.rooms?.[0]?.rates?.[0]?.rateKey;
+  const path = `/hotels/${props.hotel.code}`;
+  const query: Record<string, string> = {};
+  if (rateKey) query.rateKey = rateKey;
+  if (route.query.checkIn) query.checkIn = String(route.query.checkIn);
+  if (route.query.checkOut) query.checkOut = String(route.query.checkOut);
+  if (route.query.adults) query.adults = String(route.query.adults);
+  if (route.query.children) query.children = String(route.query.children);
+  if (route.query.rooms) query.rooms = String(route.query.rooms);
+  return { path, query };
+});
+
+const props = defineProps<{ 
+  hotel: HotelItem;
+  compact?: boolean; // true when map is open (sidebar layout)
+}>();
+const { isFavorite, toggleFavorite } = useFavorites();
+
+const minPrice = computed(() => {
+  if (!props.hotel.rooms?.length) return 0;
+  const prices = props.hotel.rooms.flatMap(room => room.rates.map(rate => rate.price.net));
+  return Math.min(...prices);
+});
+
+const rating = computed(() => (props.hotel as { reviewScore?: number }).reviewScore ?? (props.hotel.stars === 5 ? 9.2 : props.hotel.stars === 4 ? 8.5 : 7.8));
+const hotelAmenities = computed(() => AMENITIES.slice(0, props.hotel.stars === 5 ? 8 : props.hotel.stars === 4 ? 6 : 4));
+const displayedAmenities = computed(() => hotelAmenities.value.slice(0, props.compact ? 4 : 6));
+const remainingAmenitiesCount = computed(() => Math.max(0, hotelAmenities.value.length - (props.compact ? 4 : 6)));
+const galleryCount = computed(() => (props.hotel as { images?: string[] }).images?.length ?? 8);
+const compactSummary = computed(() => {
+  const h = props.hotel as { nights?: number; guests?: number };
+  const nights = h.nights ?? 2;
+  const guests = h.guests ?? 2;
+  return `${nights} kecha uchun ${guests} kishiga`;
+});
