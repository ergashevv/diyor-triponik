+
+export type BookingHolder = {
+  name: string;
+  surname: string;
+  email?: string;
+  phone?: string;
+};
+
+export type BookingRoomRequest = {
+  rateKey: string;
+  paxes: Array<{
+    roomId?: number;
+    type: 'AD' | 'CH';
+    age?: number;
+    name: string;
+    surname: string;
+  }>;
+};
+
+export type BookingRequest = {
+  holder: BookingHolder;
+  rooms: BookingRoomRequest[];
+  clientReference: string;
+  remark?: string;
+  tolerance?: number;
+};
+
+export type BookingResponse = {
+  auditData?: {
+    processTime?: number;
+    timestamp?: string;
+    token?: string;
+  };
+  booking: {
+    reference: string;
+    clientReference?: string;
+    status: 'CONFIRMED' | 'PENDING' | 'CANCELLED';
+    creationDate?: string;
+    creationUser?: string;
+    cancellationReference?: string;
+    modificationPolicies?: {
+      cancellation?: boolean;
+      modification?: boolean;
+    };
+    holder: BookingHolder;
+    hotel: {
+      name?: string;
+      categoryCode?: string;
+      categoryName?: string;
+      destinationCode?: string;
+      destinationName?: string;
+      checkIn?: string;
+      checkOut?: string;
+      rooms?: Array<{
+        code?: string;
+        name?: string;
+        status?: string;
+        paxes?: BookingRoomRequest['paxes'];
+        rates?: Rate[];
+      }>;
+    };
+    invoiceCompany?: {
+      code?: string;
+      company?: string;
+      registrationNumber?: string;
+    };
+    totalNet?: number;
+    pendingAmount?: number;
+    currency?: string;
+    remark?: string;
+  };
+};
+
+export type CancellationResponse = {
+  auditData?: {
+    processTime?: number;
+    timestamp?: string;
+    token?: string;
+  };
+  booking: {
+    reference: string;
+    cancellationReference?: string;
+    status: 'CANCELLED' | 'CONFIRMED' | string;
+    holder: BookingHolder;
+    hotel?: {
+      checkIn?: string;
+      checkOut?: string;
+      destinationCode?: string;
+      destinationName?: string;
+    };
+  };
+};
+
+export type HotelDetails = {
+  code: string;
+  name: string;
+  description?: string;
+  address?: string;
+  zip?: string;
+  city?: string;
+  destinationName?: string;
+  destinationCode?: string;
+  countryCode?: string;
+  categoryName?: string;
+  categoryCode?: string;
+  accommodationType?: string;
+  checkIn?: string;
+  checkOut?: string;
+  images?: Array<{
+    url: string;
+    alt?: string;
+  }>;
+  facilities?: string[];
+  amenities?: Array<{
+    code: string;
+    description: string;
+  }>;
+  coordinates?: {
+    lat: number;
+    lng: number;
+  };
+  latitude?: number;
+  longitude?: number;
+  rooms?: Room[];
+  attractions?: string[];
+  reviews?: {
+    overall: number;
+    cleanliness: number;
+    comfort: number;
+    location: number;
+    service: number;
+    valueForMoney: number;
+    totalReviews: number;
+  };
+  recentReviews?: Array<{
+    id: string;
+    guestName: string;
+    rating: number;
+    comment: string;
+    date: string;
+    verified: boolean;
+  }>;
+  checkInFrom?: string;
+  checkOutTo?: string;
+};
+
+// Error types
+export class ApiHttpError extends Error {
+  constructor(
+    message: string,
+    public status: number,
+    public body?: unknown
+  ) {
+    super(message);
+    this.name = 'ApiHttpError';
+  }
+}
+
+export class ApiParseError extends Error {
+  constructor(
+    message: string,
+    public issues: string[]
+  ) {
+    super(message);
+    this.name = 'ApiParseError';
+  }
+}
