+/**
+ * Hotel Details Composable
+ * 
+ * Manages fetching and displaying hotel details.
+ */
+
+import { getHotelGateway } from '~/lib/hotels';
+import type { HotelDetails } from '~/lib/hotels';
+
+export function useHotelDetails(rateKey: string | Ref<string>) {
+  const gateway = getHotelGateway();
+  
+  const loading = ref(false);
+  const error = ref<Error | null>(null);
+  const hotel = ref<HotelDetails | null>(null);
+
+  const rateKeyRef = isRef(rateKey) ? rateKey : ref(rateKey);
+
+  // Fetch hotel details
+  const fetchDetails = async () => {
+    if (!rateKeyRef.value) {
+      error.value = new Error('Rate key is required');
+      return;
+    }
+
+    loading.value = true;
+    error.value = null;
+
+    try {
+      hotel.value = await gateway.getHotelDetails(rateKeyRef.value);
+    } catch (e) {
+      error.value = e as Error;
+      hotel.value = null;
+    } finally {
+      loading.value = false;
+    }
+  };
+
+  // Computed properties
+  const minPrice = computed(() => {
+    if (!hotel.value?.rooms || hotel.value.rooms.length === 0) {
+      return null;
+    }
+
+    return Math.min(
+      ...hotel.value.rooms.flatMap((room) =>
+        room.rates.map((rate) => rate.price.net)
+      )
+    );
+  });
+
+  const maxPrice = computed(() => {
+    if (!hotel.value?.rooms || hotel.value.rooms.length === 0) {
+      return null;
+    }
+
+    return Math.max(
+      ...hotel.value.rooms.flatMap((room) =>
+        room.rates.map((rate) => rate.price.net)
+      )
+    );
+  });
+
+  const averageRating = computed(() => {
+    return hotel.value?.reviews?.overall || null;
+  });
+
+  const totalReviews = computed(() => {
+    return hotel.value?.reviews?.totalReviews || 0;
+  });
+
+  // Auto-fetch on mount
+  onMounted(() => {
+    fetchDetails();
+  });
+
+  // Watch for rateKey changes
+  watch(rateKeyRef, () => {
+    fetchDetails();
+  });
+
+  return {
+    loading,
+    error,
+    hotel,
+    minPrice,
+    maxPrice,
+    averageRating,
+    totalReviews,
+    fetchDetails,
+  };
+}
