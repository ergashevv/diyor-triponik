index 0000000..e0745f8
--- /dev/null
+++ b/server/utils/hotelbedsApi.ts
@@ -0,0 +1,134 @@
+/**
+ * Hotelbeds API reference — Booking API & Content API
+ * @see https://developer.hotelbeds.com/documentation/getting-started/
+ * @see BookingAPI.postman_collection.json, ContentAPI.postman_collection.json
+ *
+ * Barcha so'rov/javob shakllari shu formatga mos. Mock va real API bir xil normalized
+ * javob qaytaradi (adapters orqali).
+ */
+
+/** Booking API base path (proxy yoki to'g'ridan-to'g'ri Hotelbeds) */
+export const BOOKING_API_PATHS = {
+  /** POST — stay, occupancies, destination yoki hotels */
+  availability: '/hotel-api/1.0/hotels',
+  /** POST — rooms: [{ rateKey }], ixtiyoriy upselling */
+  checkrates: '/hotel-api/1.0/checkrates',
+  /** POST — booking confirm */
+  booking: '/hotel-api/1.0/bookings',
+} as const
+
+/** Content API — mehmonxona tavsifi, rasmlar, facilities */
+export const CONTENT_API_PATHS = {
+  /** GET — fields, language, from, to, codes/destinationCode/countryCode */
+  hotels: '/hotel-content-api/1.0/hotels',
+  /** GET — bitta mehmonxona batafsil */
+  hotelDetails: (code: string) => `/hotel-content-api/1.0/hotels/${code}/details`,
+} as const
+
+/**
+ * Availability request (Booking API Postman)
+ * POST hotel-api/1.0/hotels
+ */
+export type HotelbedsAvailabilityRequest = {
+  stay: { checkIn: string; checkOut: string }
+  occupancies: Array<{
+    rooms: number
+    adults: number
+    children?: number
+    paxes?: Array<{ type: 'AD' | 'CH'; age: number }>
+  }>
+  /** Destination qidiruv (kod orqali) */
+  destination?: { code: string; type?: string }
+  /** Yoki aniq hotel kodlari ro'yxati */
+  hotels?: { hotel: number[] }
+  /** Geolocation qidiruv */
+  geolocation?: { latitude: number; longitude: number; radius: number; unit?: 'km' | 'mi' }
+  filter?: { maxHotels?: number; minRate?: number; maxRate?: number; [key: string]: unknown }
+}
+
+/**
+ * Availability response (Booking API)
+ * hotels.hotels[] — har bir hotel: code (number), name, rooms[].rates[].rateKey, net (string)
