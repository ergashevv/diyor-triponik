+import type {
+  HotelSearchRequest,
+  HotelSearchResponse,
+  HotelDetails,
+  CheckRateRequest,
+  CheckRateResponse,
+  BookingRequest,
+  BookingResponse,
+  DestinationSuggestion,
+} from './types';
+
+/**
+ * Hotel Gateway Interface
+ * 
+ * This interface defines all hotel-related operations.
+ * Implementations can be real (API) or mock (local data).
+ */
+export interface HotelGateway {
+  /**
+   * Search for hotels based on criteria
+   */
+  searchHotels(params: HotelSearchRequest): Promise<HotelSearchResponse>;
+
+  /**
+   * Get detailed information about a specific hotel
+   * @param rateKey - The rate key from search results or hotel code
+   */
+  getHotelDetails(rateKey: string): Promise<HotelDetails>;
+
+  /**
+   * Check rate availability and get updated pricing
+   */
+  checkRate(params: CheckRateRequest): Promise<CheckRateResponse>;
+
+  /**
+   * Create a hotel booking
+   */
+  book(payload: BookingRequest): Promise<BookingResponse>;
+
+  /**
+   * Get destination suggestions for autocomplete
+   */
+  getSuggestions(query: string): Promise<DestinationSuggestion[]>;
+
+  /**
+   * Cancel an existing booking
+   */
+  cancelBooking(bookingReference: string): Promise<{ success: boolean; message: string }>;
+}
