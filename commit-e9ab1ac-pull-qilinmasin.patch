+/**
+ * Mock API Implementation for Triponik Hotel Search
+ * 
+ * This provides a complete mock backend that replicates the Hotelbeds API structure.
+ * It supports all major endpoints: search, details, suggestions, and booking.
+ * 
+ * Usage: Works seamlessly with the existing frontend - just change the gateway mode.
+ */
+
+import type {
+  HotelSearchRequest,
+  HotelSearchResponse,
+  HotelItem,
+  HotelDetails,
+  DestinationSuggestion,
+  BookingRequest,
+  BookingResponse,
+} from './types';
+import { ApiHttpError } from './types';
+import {
+  MOCK_DESTINATIONS,
+  HOTELBEDS_COUNTRIES,
+  AMENITIES,
+} from './mockData';
+import {
+  random,
+  generateHotel,
+  findDestination,
+  sortHotels,
+  paginate,
+  simulateDelay,
+  generateGallery,
+  generateAmenities,
+  generateReviewsSummary,
+  generateReviews,
+  getAttractions,
+  generateHotelDescription,
+  generateId,
+  logMockRequest,
+  logMockResponse,
+} from './mockUtils';
+
+// In-memory storage for generated hotels (simulates database)
+const hotelCache = new Map<string, HotelItem>();
+
+/**
+ * POST /hotels/search
+ * Search hotels by destination, dates, and occupancy
+ */
+export async function searchHotels(request: HotelSearchRequest): Promise<HotelSearchResponse> {
+  logMockRequest('/hotels/search', 'POST', request);
+  
+  // Simulate network delay
+  await simulateDelay();
+  
+  // Validate request
+  if (!request.stay || !request.stay.checkIn || !request.stay.checkOut) {
+    throw new ApiHttpError('Invalid stay dates', 400, { code: 'INVALID_DATES' });
+  }
+  
+  if (!request.occupancies || request.occupancies.length === 0) {
+    throw new ApiHttpError('Invalid occupancies', 400, { code: 'INVALID_OCCUPANCIES' });
+  }
+  
+  const { stay, occupancies, filter, pagination, sort } = request;
+  const adults = occupancies[0]?.adults || 2;
+  const children = occupancies[0]?.children || 0;
+  
+  // Find destination
+  let destination: DestinationSuggestion | undefined;
+  
+  if (filter?.destination) {
+    if ('keyword' in filter.destination) {
+      destination = findDestination(filter.destination.keyword);
+    } else if ('code' in filter.destination) {
+      const destFilter = filter.destination as { code: string };
+      destination = MOCK_DESTINATIONS.find(d => d.id === destFilter.code);
+    }
+  }
+  
+  // Default to Tashkent if not found
+  if (!destination) {
+    destination = MOCK_DESTINATIONS[0];
+  }
+  
+  // Generate full mock list (Hotelbeds-style: enough variety and count)
+  const hotelCount = Math.min(filter?.maxHotels ?? random.int(35, 60), 100);
+  const hotels: HotelItem[] = [];
+  const sameCountry = MOCK_DESTINATIONS.filter(d => d.countryCode === destination.countryCode);
+  const destinationsForVariety = sameCountry.length ? sameCountry : [destination];
+  
+  for (let i = 0; i < hotelCount; i++) {
+    const dest = i < 8 ? destination : random.pick(destinationsForVariety);
+    const stars = random.pick([3, 3, 4, 4, 4, 5]);
+    const hotel = generateHotel(dest, i + 1, stars, adults, children);
+    hotels.push(hotel);
+    hotelCache.set(hotel.code, hotel);
+  }
+  
+  // Apply filters (if provided)
+  let filteredHotels = hotels;
+  
+  // Apply sorting
+  if (sort) {
+    filteredHotels = sortHotels(filteredHotels, sort.by, sort.order);
+  }
+  
+  // Apply pagination
+  const from = pagination?.from || 0;
+  const size = pagination?.size || 25;
+  const paginatedHotels = paginate(filteredHotels, from, size);
+  
+  const startTime = Date.now();
+  const response: HotelSearchResponse = {
+    checkIn: stay.checkIn,
+    checkOut: stay.checkOut,
+    currency: request.currency || 'USD',
+    total: filteredHotels.length,
+    hotels: paginatedHotels,
+    meta: {
+      pageFrom: from,
+      pageSize: size,
+      tookMs: Date.now() - startTime + random.int(100, 500),
+    },
+  };
+  
+  logMockResponse('/hotels/search', response);
+  return response;
+}
+
+/**
+ * GET /hotels/:id
+ * Get hotel details by ID or rateKey
+ */
+export async function getHotelDetails(idOrRateKey: string): Promise<HotelDetails> {
+  logMockRequest(`/hotels/${idOrRateKey}`, 'GET');
+  await simulateDelay();
+  
+  // Try to get from cache first
+  let hotel = hotelCache.get(idOrRateKey);
+  
+  // If not in cache, generate a new one
+  if (!hotel) {
+    const destination = MOCK_DESTINATIONS[0];
+    const stars = random.pick([3, 4, 5]);
+    hotel = generateHotel(destination, 1, stars, 2, 0);
+    hotel.code = idOrRateKey; // Override code with requested ID
+    hotelCache.set(idOrRateKey, hotel);
+  }
+  
+  // Build detailed response
+  const amenityIds = generateAmenities(hotel.stars || 4);
+  const amenityDetails = amenityIds.map(id => 
+    AMENITIES.find(a => a.id === id)
+  ).filter(Boolean);
+  
+  const details: HotelDetails = {
+    code: hotel.code,
+    name: hotel.name,
+    description: generateHotelDescription(hotel.stars || 4),
+    address: hotel.address,
+    city: hotel.city,
+    countryCode: hotel.countryCode,
+    categoryName: hotel.categoryName,
+    latitude: hotel.latitude,
+    longitude: hotel.longitude,
+    images: generateGallery().map((url, idx) => ({
+      url,
+      alt: `${hotel.name} - Rasm ${idx + 1}`,
+    })),
+    amenities: amenityDetails.map(a => ({
+      code: a!.id,
+      description: a!.name,
+    })),
+    rooms: hotel.rooms,
+    attractions: getAttractions(hotel.city || 'default'),
+    reviews: generateReviewsSummary(hotel.stars || 4),
+    recentReviews: generateReviews(5),
+  };
+  
+  logMockResponse(`/hotels/${idOrRateKey}`, details);
+  return details;
+}
+
+/**
+ * GET /hotels/suggest?query=
+ * Destination autocomplete — Hotelbeds-style: by city name, code, or country.
+ */
+export async function getSuggestions(query: string): Promise<DestinationSuggestion[]> {
+  logMockRequest(`/hotels/suggest?query=${query}`, 'GET');
+  await simulateDelay(200, 400);
+  
+  if (!query || query.length < 1) {
+    return [];
+  }
+  
+  const normalized = query.toLowerCase().trim();
+  const byCityOrCode = MOCK_DESTINATIONS.filter(
+    (dest) =>
+      dest.name.toLowerCase().includes(normalized) ||
+      dest.id.toLowerCase().includes(normalized)
+  );
+  const byCountry = HOTELBEDS_COUNTRIES.filter(
+    (c) => c.name.toLowerCase().includes(normalized) || c.code.toLowerCase() === normalized
+  );
+  const byCountryDestinations = byCountry.length
+    ? MOCK_DESTINATIONS.filter((d) => byCountry.some((c) => c.code === d.countryCode))
+    : [];
+  const combined = [...byCityOrCode];
+  byCountryDestinations.forEach((d) => {
+    if (!combined.some((x) => x.id === d.id)) combined.push(d);
+  });
+  
+  logMockResponse('/hotels/suggest', combined);
+  return combined;
+}
+
+/**
