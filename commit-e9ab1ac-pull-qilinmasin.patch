+<script setup lang="ts">
+import type { HotelItem, Room, Rate } from '~/lib/hotels';
+import { AMENITIES } from '~/lib/hotels';
+import { useFavorites } from '~/composables/useFavorites';
+
+const props = withDefaults(
+  defineProps<{
+    hotel: HotelItem;
+    nights?: number;
+    guests?: number;
+  }>(),
+  { nights: 2, guests: 2 }
+);
+
+const route = useRoute();
+const { isFavorite, toggleFavorite } = useFavorites();
+
+/** Detail sahifaga havola: rateKey + sanalar (karta bosilganda inner page ga kirish) */
+const detailTo = computed(() => {
+  const rateKey = props.hotel.rooms?.[0]?.rates?.[0]?.rateKey;
+  const path = `/hotels/${props.hotel.code}`;
+  const query: Record<string, string> = {};
+  if (rateKey) query.rateKey = rateKey;
+  if (route.query.checkIn) query.checkIn = String(route.query.checkIn);
+  if (route.query.checkOut) query.checkOut = String(route.query.checkOut);
+  if (route.query.adults) query.adults = String(route.query.adults);
+  if (route.query.children) query.children = String(route.query.children);
+  if (route.query.rooms) query.rooms = String(route.query.rooms);
+  return { path, query };
+});
+
+const gallery = computed(() => props.hotel.images?.length ? props.hotel.images : [props.hotel.thumbnail || 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800']);
+const galleryLength = computed(() => gallery.value.length);
+const currentIndex = ref(0);
+const currentImage = computed(() => gallery.value[currentIndex.value] ?? gallery.value[0]);
+
+function prevImage() {
+  currentIndex.value = (currentIndex.value - 1 + galleryLength.value) % galleryLength.value;
+}
+function nextImage() {
+  currentIndex.value = (currentIndex.value + 1) % galleryLength.value;
+}
+
+const room = computed<Room | undefined>(() => props.hotel.rooms?.[0]);
+const firstRate = computed<Rate | undefined>(() => room.value?.rates?.[0]);
+
+const displayScore = computed(() => (props.hotel.reviewScore != null ? String(props.hotel.reviewScore) : (props.hotel.stars === 5 ? '9.2' : props.hotel.stars === 4 ? '8.5' : '7.8')));
+
+const locationLine = computed(() => {
+  if (props.hotel.address && props.hotel.city) return `${props.hotel.address}, ${props.hotel.city}`;
+  return props.hotel.address || props.hotel.city || '';
+});
+
+const hasBreakfast = computed(() => firstRate.value?.boardCode === 'BB' || firstRate.value?.boardName?.toLowerCase().includes('nonushta'));
+
+const displayedAmenities = computed(() => AMENITIES.slice(0, 6));
+const reviewDotCount = computed(() => Math.round((props.hotel.reviewScore ?? 8) / 2));
+
+const displayPrice = computed(() => {
+  const rate = firstRate.value;
+  if (!rate?.price?.net) return '0';
+  const total = rate.price.net * props.nights;
+  return String(Math.round(total));
+});
