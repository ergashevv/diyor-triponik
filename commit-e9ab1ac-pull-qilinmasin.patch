+/**
+ * Hotel Search Composable
+ * 
+ * Manages hotel search state, form validation, and API calls.
+ * Syncs search parameters with URL query params for shareable links.
+ */
+
+import { getHotelGateway } from '~/lib/hotels';
+import type { HotelSearchRequest, HotelSearchResponse, DestinationSuggestion } from '~/lib/hotels';
+
+export interface SearchFormData {
+  destination: string;
+  destinationCode?: string;
+  checkIn: string;
+  checkOut: string;
+  adults: number;
+  children: number;
+  rooms: number;
+}
+
+export function useHotelSearch() {
+  const gateway = getHotelGateway();
+  const route = useRoute();
+  const router = useRouter();
+
+  // State
+  const loading = ref(false);
+  const error = ref<Error | null>(null);
+  const results = ref<HotelSearchResponse | null>(null);
+  const suggestions = ref<DestinationSuggestion[]>([]);
+  const loadingSuggestions = ref(false);
+
+  // Form data with defaults
+  const formData = ref<SearchFormData>({
+    destination: '',
+    destinationCode: '',
+    checkIn: '',
+    checkOut: '',
+    adults: 2,
+    children: 0,
+    rooms: 1,
+  });
+
+  // Initialize from URL query params
+  const initializeFromUrl = () => {
+    if (route.query.destination) {
+      formData.value.destination = route.query.destination as string;
+    }
+    if (route.query.destinationCode) {
+      formData.value.destinationCode = route.query.destinationCode as string;
+    }
+    if (route.query.checkIn) {
+      formData.value.checkIn = route.query.checkIn as string;
+    }
+    if (route.query.checkOut) {
+      formData.value.checkOut = route.query.checkOut as string;
+    }
+    if (route.query.adults) {
+      formData.value.adults = parseInt(route.query.adults as string, 10);
+    }
+    if (route.query.children) {
+      formData.value.children = parseInt(route.query.children as string, 10);
+    }
+    if (route.query.rooms) {
+      formData.value.rooms = parseInt(route.query.rooms as string, 10);
+    }
+  };
+
+  // Sync form data to URL
+  const syncToUrl = () => {
+    router.push({
+      query: {
+        destination: formData.value.destination,
+        destinationCode: formData.value.destinationCode,
+        checkIn: formData.value.checkIn,
+        checkOut: formData.value.checkOut,
+        adults: formData.value.adults.toString(),
+        children: formData.value.children.toString(),
+        rooms: formData.value.rooms.toString(),
+      },
+    });
+  };
+
+  // Validate form data
+  const validate = (): { valid: boolean; errors: string[] } => {
+    const errors: string[] = [];
+
+    if (!formData.value.destination) {
+      errors.push('Manzilni tanlang');
+    }
+
+    if (!formData.value.checkIn) {
+      errors.push('Kirish sanasini tanlang');
+    }
+
+    if (!formData.value.checkOut) {
+      errors.push('Chiqish sanasini tanlang');
+    }
+
+    if (formData.value.checkIn && formData.value.checkOut) {
+      const checkIn = new Date(formData.value.checkIn);
+      const checkOut = new Date(formData.value.checkOut);
+      
+      if (checkOut <= checkIn) {
+        errors.push('Chiqish sanasi kirish sanasidan keyin bo\'lishi kerak');
+      }
+
+      const today = new Date();
+      today.setHours(0, 0, 0, 0);
+      
+      if (checkIn < today) {
+        errors.push('Kirish sanasi bugundan oldin bo\'lishi mumkin emas');
+      }
+    }
+
+    if (formData.value.adults < 1) {
+      errors.push('Kamida 1 kattalar bo\'lishi kerak');
+    }
+
+    if (formData.value.rooms < 1) {
+      errors.push('Kamida 1 xona bo\'lishi kerak');
+    }
+
+    return {
+      valid: errors.length === 0,
+      errors,
+    };
+  };
+
+  // Search hotels
+  const search = async (syncUrl = true) => {
+    const validation = validate();
+    
+    if (!validation.valid) {
+      error.value = new Error(validation.errors.join(', '));
+      return;
+    }
+
+    loading.value = true;
+    error.value = null;
+
+    try {
+      const params: HotelSearchRequest = {
+        stay: {
+          checkIn: formData.value.checkIn,
+          checkOut: formData.value.checkOut,
+        },
+        occupancies: [
+          {
+            rooms: formData.value.rooms,
+            adults: formData.value.adults,
+            children: formData.value.children,
+          },
+        ],
+        filter: {
+          destination: formData.value.destinationCode
+            ? { code: formData.value.destinationCode }
+            : { keyword: formData.value.destination },
+        },
+      };
+
+      results.value = await gateway.searchHotels(params);
+
+      // Sync to URL for shareable links
+      if (syncUrl) {
+        syncToUrl();
+      }
+
+      // Save to search history
+      saveToHistory();
+    } catch (e) {
+      error.value = e as Error;
+      results.value = null;
+    } finally {
+      loading.value = false;
+    }
+  };
+
+  // Get destination suggestions
+  const getSuggestions = async (query: string) => {
+    if (!query || query.length < 2) {
+      suggestions.value = [];
+      return;
+    }
+
+    loadingSuggestions.value = true;
+
+    try {
+      suggestions.value = await gateway.getSuggestions(query);
+    } catch (e) {
+      console.error('Failed to get suggestions:', e);
+      suggestions.value = [];
+    } finally {
+      loadingSuggestions.value = false;
+    }
+  };
+
+  // Select a destination from suggestions
+  const selectDestination = (destination: DestinationSuggestion) => {
+    formData.value.destination = destination.name;
+    formData.value.destinationCode = destination.id;
+    suggestions.value = [];
+  };
+
+  // Save search to history (localStorage)
+  const saveToHistory = () => {
+    try {
+      const history = JSON.parse(localStorage.getItem('hotelSearchHistory') || '[]');
+      const newEntry = {
+        ...formData.value,
+        timestamp: Date.now(),
+      };
+      
+      // Keep only last 10 searches
+      history.unshift(newEntry);
+      if (history.length > 10) {
+        history.pop();
+      }
+      
+      localStorage.setItem('hotelSearchHistory', JSON.stringify(history));
+    } catch (e) {
+      console.error('Failed to save search history:', e);
+    }
+  };
+
+  // Get search history
+  const getHistory = () => {
+    try {
+      return JSON.parse(localStorage.getItem('hotelSearchHistory') || '[]');
+    } catch (e) {
+      return [];
+    }
+  };
+
+  // Clear search history
+  const clearHistory = () => {
+    localStorage.removeItem('hotelSearchHistory');
+  };
+
+  // Set default dates (today + 7 days to today + 12 days)
+  const setDefaultDates = () => {
+    const today = new Date();
+    const checkIn = new Date(today);
+    checkIn.setDate(today.getDate() + 7);
+    
+    const checkOut = new Date(checkIn);
+    checkOut.setDate(checkIn.getDate() + 5);
+    
+    formData.value.checkIn = checkIn.toISOString().split('T')[0];
+    formData.value.checkOut = checkOut.toISOString().split('T')[0];
+  };
+
+  // Initialize on mount
+  onMounted(() => {
+    initializeFromUrl();
+    
+    // Set default dates if not provided
+    if (!formData.value.checkIn || !formData.value.checkOut) {
+      setDefaultDates();
+    }
+  });
+
+  return {
+    // State
+    loading,
+    error,
+    results,
+    formData,
+    suggestions,
+    loadingSuggestions,
+
+    // Methods
+    search,
+    getSuggestions,
+    selectDestination,
+    validate,
+    setDefaultDates,
+    
+    // History
+    getHistory,
+    clearHistory,
+    
+    // URL sync
+    initializeFromUrl,
+    syncToUrl,
+  };
+}
