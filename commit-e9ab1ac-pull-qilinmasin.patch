+/**
+ * Hotel Module - Main Export
+ * 
+ * This module provides a complete hotel booking system with:
+ * - Real API integration (via Nuxt server routes)
+ * - Professional mock API (indistinguishable from real)
+ * - Automatic fallback (real → mock on any failure)
+ * 
+ * Usage:
+ * ```ts
+ * import { getHotelGateway } from '~/lib/hotels';
+ * 
+ * const gateway = getHotelGateway();
+ * const results = await gateway.searchHotels({ ... });
+ * ```
+ */
+
+// Main gateway (use this in your app)
+export { getHotelGateway, GatewayResolver } from './gatewayResolver';
+
+// Types
+export type {
+  HotelSearchRequest,
+  HotelSearchResponse,
+  HotelItem,
+  HotelDetails,
+  DestinationSuggestion,
+  Room,
+  Rate,
+  Occupancy,
+  Stay,
+  CheckRateRequest,
+  CheckRateResponse,
+  BookingRequest,
+  BookingResponse,
+  BookingHolder,
+  CancellationResponse,
+} from './types';
+
+// Gateway interface (for custom implementations)
+export type { HotelGateway } from './gateway';
+
+// Individual gateways (for advanced usage)
+export { RealHotelGateway } from './realGateway';
+export { MockHotelGateway } from './mockGateway';
+
+// Mock data (for testing/development, Hotelbeds-aligned)
+export {
+  MOCK_DESTINATIONS,
+  HOTELBEDS_COUNTRIES,
+  COUNTRY_NAMES_BY_CODE,
+  AMENITIES,
+  BOARD_TYPES,
+  PAYMENT_TYPES,
+} from './mockData';
+
+// Error classes
+export { ApiHttpError, ApiParseError } from './types';
