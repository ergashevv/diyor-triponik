+import type { HotelGateway } from './gateway';
+import type {
+  HotelSearchRequest,
+  HotelSearchResponse,
+  HotelDetails,
+  CheckRateRequest,
+  CheckRateResponse,
+  BookingRequest,
+  BookingResponse,
+  DestinationSuggestion,
+} from './types';
+
+/**
+ * Real Hotel Gateway
+ * 
+ * Calls the Nuxt server API routes which proxy to the real Hotelbeds API.
+ * Matches the exact implementation from triponik-old.
+ */
+export class RealHotelGateway implements HotelGateway {
+  private baseUrl: string;
+
+  constructor(baseUrl = '/api/hotels') {
+    this.baseUrl = baseUrl;
+  }
+
+  async searchHotels(params: HotelSearchRequest): Promise<HotelSearchResponse> {
+    const response = await $fetch<HotelSearchResponse>(`${this.baseUrl}/availability`, {
+      method: 'POST',
+      body: params,
+    });
+    return response;
+  }
+
+  async getHotelDetails(rateKey: string): Promise<HotelDetails> {
+    // Use the detail endpoint which calls checkrate internally
+    const response = await $fetch<{ hotel: HotelDetails }>(`${this.baseUrl}/detail`, {
+      method: 'POST',
+      body: {
+        rooms: [{ rateKey }],
+      },
+    });
+    return response.hotel;
+  }
+
+  async checkRate(params: CheckRateRequest): Promise<CheckRateResponse> {
+    const response = await $fetch<CheckRateResponse>(`${this.baseUrl}/checkrate`, {
+      method: 'POST',
+      body: params,
+    });
+    return response;
+  }
+
+  async book(payload: BookingRequest): Promise<BookingResponse> {
+    const response = await $fetch<BookingResponse>(`${this.baseUrl}/booking`, {
+      method: 'POST',
+      body: payload,
+    });
+    return response;
+  }
+
+  async getSuggestions(query: string): Promise<DestinationSuggestion[]> {
+    const response = await $fetch<DestinationSuggestion[]>(`${this.baseUrl}/suggest`, {
+      method: 'GET',
+      query: { query },
+    });
+    return response;
+  }
+
+  async cancelBooking(bookingReference: string): Promise<{ success: boolean; message: string }> {
+    const response = await $fetch<{ success: boolean; message: string }>(
+      `${this.baseUrl}/cancel/${bookingReference}`,
+      {
+        method: 'DELETE',
+      }
+    );
+    return response;
+  }
+}
