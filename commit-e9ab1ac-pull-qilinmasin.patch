+import { z } from 'zod';
+
+// Base types
+export type Occupancy = {
+  rooms: number;
+  adults: number;
+  children: number;
+  paxes?: Array<{ age: number }>;
+};
+
+export type Stay = {
+  checkIn: string; // ISO yyyy-mm-dd
+  checkOut: string; // ISO yyyy-mm-dd
+};
+
+export type GeoFilter = {
+  latitude: number;
+  longitude: number;
+  radius: number;
+  unit?: 'km' | 'mi';
+};
+
+export type DestinationFilter = 
+  | { code: string } 
+  | { keyword: string };
+
+export type HotelSearchRequest = {
+  stay: Stay;
+  occupancies: Occupancy[];
+  filter: {
+    destination?: DestinationFilter;
+    geolocation?: GeoFilter;
+    maxHotels?: number;
+    minRate?: number;
+    maxRate?: number;
+    hotelName?: string;
+    hotels?: {
+      hotel: Array<string | number>;
+    };
+  };
+  language?: string;
+  currency?: string;
+  nationality?: string;
+  pagination?: {
+    from?: number;
+    size?: number;
+  };
+  sort?: {
+    by: 'price' | 'stars' | 'distance';
+    order: 'asc' | 'desc';
+  };
+};
+
+export type Rate = {
+  rateKey: string;
+  boardCode?: string;
+  boardName?: string;
+  paymentType: 'AT_WEB' | 'AT_HOTEL';
+  refundable: boolean;
+  cancellationPolicies?: Array<{
+    from: string;
+    amount: number;
+    currency: string;
+  }>;
+  price: {
+    net: number;
+    selling?: number;
+    currency: string;
+    taxesIncluded?: boolean;
+  };
+};
+
+export type Room = {
+  code: string;
+  name: string;
+  rates: Rate[];
+  maxAdults?: number;
+  maxChildren?: number;
+  /** Yotoq tavsifi, masalan "katta ikki kishilik yotoq" */
+  bedConfiguration?: string;
+  /** Xona maydoni m² */
+  sizeSquareMeters?: number;
+  /** Ko'rinish turi, masalan "Shahar ko'rinishi" */
+  viewType?: string;
+};
+
+export type HotelItem = {
+  code: string;
+  name: string;
+  categoryName?: string;
+  stars?: number;
+  latitude?: number;
+  longitude?: number;
+  distance?: number;
+  /** Metro stansiyasidan masofa (m) — katta kartochka uchun */
+  distanceFromMetro?: number;
+  address?: string;
+  city?: string;
+  countryCode?: string;
+  thumbnail?: string;
+  /** Galereya rasmlari (katta kartochka slider uchun) */
+  images?: string[];
+  rooms: Room[];
+  /** Sharhlar soni — katta kartochka uchun */
+  reviewCount?: number;
+  /** Umumiy reyting (masalan 9.2) — katta kartochka uchun */
+  reviewScore?: number;
+  /** TOP badge ko'rsatish */
+  isTopRated?: boolean;
+};
+
+export type HotelSearchResponse = {
+  checkIn: string;
+  checkOut: string;
+  currency: string;
+  total: number;
+  hotels: HotelItem[];
+  meta?: {
+    pageFrom?: number;
+    pageSize?: number;
+    tookMs?: number;
+  };
+};
+
+export type DestinationSuggestion = {
+  id: string;
+  name: string;
+  countryCode?: string;
+  type: 'CITY' | 'AIRPORT' | 'REGION' | 'HOTEL';
+  lat?: number;
+  lng?: number;
+};
+
+export type CheckRateRequest = {
+  upselling?: boolean;
+  rooms: Array<{
+    rateKey: string;
+    paxes?: Array<{
+      type: 'AD' | 'CH';
+      age?: number;
+      name?: string;
+      surname?: string;
+    }>;
+  }>;
+};
+
+export type CheckRateResponse = {
+  auditData?: {
+    processTime?: number;
+    timestamp?: string;
+    token?: string;
+  };
+  hotel: {
+    code: string;
