+# ============================================
+# TRIPONIK - Environment Variables
+# ============================================
 
-# Hotel API Configuration
-# Base URL for the hotel availability API
+# --------------------------------------------
+# Hotel Module Configuration
+# --------------------------------------------
+
+# Server: faqat mock (API ishlamaganda). Availability va Detail darhol mock qaytaradi.
+# Vaqtincha API yoqilmaganda: HOTEL_USE_MOCK=true
+HOTEL_USE_MOCK=true
+
+# Force mock mode (client gateway — always use mock data, never call real API)
+FORCE_MOCK=false
+
+# Force real mode (always use real API, fail if unavailable)
+FORCE_REAL=false
+
+# Hotel API Base URL (for real mode)
 NUXT_PUBLIC_HOTEL_API_BASE_URL=https://api.triponik.uz
-# Hotel API credentials (Basic Auth)
+
+# Hotel API Credentials (server-side only)
 HOTEL_API_USERNAME=diyorbek
-HOTEL_API_PASSWORD=Mulan2025...
\ No newline at end of file
+HOTEL_API_PASSWORD=Mulan2025...
+
+# --------------------------------------------
+# Application Configuration
+# --------------------------------------------
+
+# Base URL for the application
+BASE_URL=http://localhost:3000
+
+# API Base URL (Nuxt server routes)
+NUXT_PUBLIC_API_BASE_URL=/api
+
+# --------------------------------------------
+# Development Settings
+# --------------------------------------------
+
+# Enable debug logging
+NODE_ENV=development
+
+# --------------------------------------------
+# USAGE EXAMPLES
+# --------------------------------------------
+
+# 1. Development with auto-fallback (recommended):
+#    No changes needed, just run: npm run dev
+
+# 2. API ishlamayapti — vaqtincha faqat mock (recommended):
+#    Set HOTEL_USE_MOCK=true in .env, then run: npm run dev
+
+# 3. Production testing with real API only:
+#    Set FORCE_REAL=true, then run: npm run dev
+
+# 4. Production deployment:
+#    Set real credentials and run: npm run build && npm run start
