new file mode 100644
index 0000000..ee8c115
--- /dev/null
+++ b/app/lib/hotels/gatewayResolver.ts
@@ -0,0 +1,256 @@
+import type { HotelGateway } from './gateway';
+import { RealHotelGateway } from './realGateway';
+import { MockHotelGateway } from './mockGateway';
+import type {
+  HotelSearchRequest,
+  HotelSearchResponse,
+  HotelDetails,
+  CheckRateRequest,
+  CheckRateResponse,
+  BookingRequest,
+  BookingResponse,
+  DestinationSuggestion,
+} from './types';
+
+type GatewayMode = 'real' | 'mock' | 'auto';
+
+/**
+ * Gateway Resolver with Automatic Fallback
+ * 
+ * This class implements the automatic fallback logic:
+ * 1. Try real API first (if not forced to mock)
+ * 2. If real API fails → automatically switch to mock
+ * 3. Mock is indistinguishable from real API
+ * 
+ * Environment variables:
+ * - FORCE_MOCK=true → always use mock
+ * - FORCE_REAL=true → always use real (fail if unavailable)
+ * - default → auto-fallback enabled
+ */
+export class GatewayResolver implements HotelGateway {
+  private realGateway: RealHotelGateway;
+  private mockGateway: MockHotelGateway;
+  private mode: GatewayMode;
+  private currentGateway: HotelGateway;
+  private failureCount = 0;
+  private maxFailures = 3;
+
+  constructor() {
+    this.realGateway = new RealHotelGateway();
+    this.mockGateway = new MockHotelGateway();
+    
+    // Determine mode from environment
+    const forceMock = this.getEnvFlag('FORCE_MOCK');
+    const forceReal = this.getEnvFlag('FORCE_REAL');
+    
+    if (forceMock) {
+      this.mode = 'mock';
+      this.currentGateway = this.mockGateway;
+      if (process.dev) {
+        console.log('[HotelGateway] Mode: FORCE_MOCK');
+      }
+    } else if (forceReal) {
+      this.mode = 'real';
+      this.currentGateway = this.realGateway;
+      if (process.dev) {
+        console.log('[HotelGateway] Mode: FORCE_REAL');
+      }
+    } else {
+      this.mode = 'auto';
+      this.currentGateway = this.realGateway; // Start with real
+      if (process.dev) {
+        console.log('[HotelGateway] Mode: AUTO (real with fallback to mock)');
+      }
+    }
+  }
+
+  private getEnvFlag(key: string): boolean {
+    if (typeof window !== 'undefined') {
+      // Client-side: check runtime config
+      const config = useRuntimeConfig();
+      return config.public[key.toLowerCase()] === 'true' || config.public[key.toLowerCase()] === true;
+    }
+    // Server-side
+    return process.env[key] === 'true';
+  }
+
+  /**
+   * Execute a gateway method with automatic fallback
+   */
+  private async executeWithFallback<T>(
+    methodName: string,
+    realFn: () => Promise<T>,
+    mockFn: () => Promise<T>
+  ): Promise<T> {
+    // If forced to mock, use mock directly
+    if (this.mode === 'mock') {
+      return mockFn();
+    }
+
+    // If forced to real, use real and fail if it doesn't work
+    if (this.mode === 'real') {
+      try {
+        return await realFn();
+      } catch (error) {
+        console.error(`[HotelGateway] ${methodName} failed (FORCE_REAL mode):`, error);
+        throw error;
+      }
+    }
+
+    // Auto mode: try real, fallback to mock on error
+    try {
+      const result = await realFn();
+      
+      // Reset failure count on success
+      if (this.failureCount > 0) {
+        this.failureCount = 0;
+        if (process.dev) {
+          console.log('[HotelGateway] Real API recovered, failure count reset');
+        }
+      }
+      
+      return result;
+    } catch (error: any) {
+      this.failureCount++;
+      
+      // Check if we should switch to mock permanently
+      const shouldFallback = this.shouldFallbackToMock(error);
+      
+      if (shouldFallback) {
+        if (process.dev) {
+          console.warn(
+            `[HotelGateway] ${methodName} failed, falling back to mock (failure ${this.failureCount}/${this.maxFailures})`,
+            error
+          );
+        }
+        
+        // If we've hit max failures, switch to mock permanently for this session
+        if (this.failureCount >= this.maxFailures) {
+          this.currentGateway = this.mockGateway;
+          if (process.dev) {
+            console.warn('[HotelGateway] Switched to mock mode after repeated failures');
+          }
+        }
+        
+        // Use mock as fallback
+        return mockFn();
+      }
+      
+      // If error is not fallback-worthy, throw it
+      throw error;
+    }
+  }
+
+  /**
+   * Determine if an error should trigger fallback to mock
+   */
+  private shouldFallbackToMock(error: any): boolean {
+    // Network errors
+    if (error.name === 'FetchError' || error.message?.includes('fetch')) {
+      return true;
+    }
+    
+    // HTTP errors (4xx, 5xx)
+    if (error.status >= 400) {
+      return true;
+    }
+    
+    // CORS errors
+    if (error.message?.includes('CORS')) {
+      return true;
+    }
+    
+    // Timeout errors
+    if (error.message?.includes('timeout')) {
+      return true;
+    }
+    
+    // Schema validation errors
+    if (error.name === 'ApiParseError') {
+      return true;
+    }
+    
+    // Generic network/server errors
+    if (error.message?.includes('Network') || error.message?.includes('Server')) {
+      return true;
+    }
+    
+    return false;
+  }
+
+  // Implement HotelGateway interface
+  async searchHotels(params: HotelSearchRequest): Promise<HotelSearchResponse> {
+    return this.executeWithFallback(
+      'searchHotels',
+      () => this.realGateway.searchHotels(params),
+      () => this.mockGateway.searchHotels(params)
+    );
+  }
+
+  async getHotelDetails(rateKey: string): Promise<HotelDetails> {
+    return this.executeWithFallback(
+      'getHotelDetails',
+      () => this.realGateway.getHotelDetails(rateKey),
+      () => this.mockGateway.getHotelDetails(rateKey)
+    );
+  }
+
+  async checkRate(params: CheckRateRequest): Promise<CheckRateResponse> {
+    return this.executeWithFallback(
+      'checkRate',
+      () => this.realGateway.checkRate(params),
+      () => this.mockGateway.checkRate(params)
+    );
+  }
+
+  async book(payload: BookingRequest): Promise<BookingResponse> {
+    return this.executeWithFallback(
+      'book',
+      () => this.realGateway.book(payload),
+      () => this.mockGateway.book(payload)
+    );
+  }
+
+  async getSuggestions(query: string): Promise<DestinationSuggestion[]> {
+    return this.executeWithFallback(
+      'getSuggestions',
+      () => this.realGateway.getSuggestions(query),
+      () => this.mockGateway.getSuggestions(query)
+    );
+  }
+
+  async cancelBooking(bookingReference: string): Promise<{ success: boolean; message: string }> {
+    return this.executeWithFallback(
+      'cancelBooking',
+      () => this.realGateway.cancelBooking(bookingReference),
+      () => this.mockGateway.cancelBooking(bookingReference)
+    );
+  }
+
+  /**
+   * Get current mode for debugging
+   */
+  getCurrentMode(): GatewayMode {
+    return this.mode;
+  }
+
+  /**
+   * Check if currently using mock
+   */
+  isUsingMock(): boolean {
+    return this.currentGateway === this.mockGateway || this.mode === 'mock';
+  }
+}
+
+// Singleton instance
+let gatewayInstance: GatewayResolver | null = null;
+
+/**
+ * Get the gateway instance (singleton)
+ */
+export function getHotelGateway(): GatewayResolver {
+  if (!gatewayInstance) {
+    gatewayInstance = new GatewayResolver();
+  }
+  return gatewayInstance;
+}
