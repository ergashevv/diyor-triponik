+/**
+ * Favorites Composable
+ * 
+ * Manages favorite hotels with localStorage persistence.
+ */
+
+import type { HotelItem } from '~/lib/hotels';
+
+export interface FavoriteHotel {
+  code: string;
+  name: string;
+  thumbnail?: string;
+  stars?: number;
+  city?: string;
+  minPrice?: number;
+  addedAt: number;
+}
+
+export function useFavorites() {
+  const favorites = ref<FavoriteHotel[]>([]);
+
+  // Load favorites from localStorage
+  const loadFavorites = () => {
+    try {
+      const stored = localStorage.getItem('hotelFavorites');
+      if (stored) {
+        favorites.value = JSON.parse(stored);
+      }
+    } catch (e) {
+      console.error('Failed to load favorites:', e);
+      favorites.value = [];
+    }
+  };
+
+  // Save favorites to localStorage
+  const saveFavorites = () => {
+    try {
+      localStorage.setItem('hotelFavorites', JSON.stringify(favorites.value));
+    } catch (e) {
+      console.error('Failed to save favorites:', e);
+    }
+  };
+
+  // Check if hotel is favorited
+  const isFavorite = (hotelCode: string): boolean => {
+    return favorites.value.some((fav) => fav.code === hotelCode);
+  };
+
+  // Add hotel to favorites
+  const addFavorite = (hotel: HotelItem) => {
+    if (isFavorite(hotel.code)) {
+      return; // Already favorited
+    }
+
+    const minPrice = hotel.rooms.length > 0
+      ? Math.min(...hotel.rooms.flatMap((room) => room.rates.map((rate) => rate.price.net)))
+      : undefined;
+
+    const favorite: FavoriteHotel = {
+      code: hotel.code,
+      name: hotel.name,
+      thumbnail: hotel.thumbnail,
+      stars: hotel.stars,
+      city: hotel.city,
+      minPrice,
+      addedAt: Date.now(),
+    };
+
+    favorites.value.unshift(favorite);
+    saveFavorites();
+  };
+
+  // Remove hotel from favorites
+  const removeFavorite = (hotelCode: string) => {
+    favorites.value = favorites.value.filter((fav) => fav.code !== hotelCode);
+    saveFavorites();
+  };
+
+  // Toggle favorite status
+  const toggleFavorite = (hotel: HotelItem) => {
+    if (isFavorite(hotel.code)) {
+      removeFavorite(hotel.code);
+    } else {
+      addFavorite(hotel);
+    }
+  };
+
+  // Clear all favorites
+  const clearFavorites = () => {
+    favorites.value = [];
+    saveFavorites();
+  };
+
+  // Get favorites count
+  const favoritesCount = computed(() => favorites.value.length);
+
+  // Initialize on mount
+  onMounted(() => {
+    loadFavorites();
+  });
+
+  return {
+    favorites,
+    favoritesCount,
+    isFavorite,
+    addFavorite,
+    removeFavorite,
+    toggleFavorite,
+    clearFavorites,
+  };
+}
